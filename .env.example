# ─────────────────────────────────────────────────────────────────────────────
# Poxyndex environment variables
# Copy to ingest/.env (for local scraper runs) and set the same values as
# GitHub Actions secrets + Vercel env vars for production. NEVER commit real keys.
# ─────────────────────────────────────────────────────────────────────────────

# --- Server side ONLY (scraper / GitHub Actions). Bypasses RLS — keep secret. ---
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here   # service_role key. NEVER ship to the browser.

# --- Public (safe to ship to the browser / Vercel). Used by the Next.js frontend. ---
# These are the SAME project, but the anon/publishable key, which is RLS-restricted.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key-here
